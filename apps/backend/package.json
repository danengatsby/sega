{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "NODE_ENV=test tsx --test src/**/*.test.ts",
    "dev": "tsx watch src/server.ts",
    "dev:auth-service": "tsx watch src/microservices/auth-service-server.ts",
    "dev:invoice-service": "tsx watch src/microservices/invoice-service-server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:auth-service": "node dist/microservices/auth-service-server.js",
    "start:invoice-service": "node dist/microservices/invoice-service-server.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:enterprise": "prisma db execute --file prisma/sql/enterprise-hardening.sql --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev",
    "db:bootstrap": "npm run prisma:push && npm run prisma:enterprise",
    "db:bootstrap:reset": "prisma db push --force-reset && npm run prisma:enterprise",
    "seed": "tsx src/seed.ts",
    "seed:demo:accountant-3companies": "tsx scripts/demo/seed-accountant-three-companies.ts",
    "anaf:smoke": "tsx scripts/anaf-smoke.ts",
    "open-banking:smoke": "tsx scripts/open-banking-smoke.ts",
    "openapi:generate": "tsx scripts/openapi/generate.ts",
    "openapi:service-contracts": "tsx scripts/openapi/generate-service-contracts.ts",
    "openapi:validate": "tsx scripts/openapi/validate.ts",
    "openapi:ci": "npm run openapi:generate && npm run openapi:service-contracts && npm run openapi:validate",
    "perf:seed": "tsx scripts/perf/seed-kpi-fixtures.ts",
    "perf:k6": "bash scripts/perf/run-k6.sh",
    "perf:k6:ci": "K6_SUMMARY_EXPORT=perf/results/k6-summary.json bash scripts/perf/run-k6.sh",
    "perf:jmeter": "bash scripts/perf/run-jmeter.sh",
    "perf:jmeter:check": "node scripts/perf/check-jmeter-jtl.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "private": true,
  "dependencies": {
    "@aws-sdk/client-s3": "^3.995.0",
    "@prisma/client": "^6.15.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "fast-xml-parser": "^5.3.6",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "otplib": "^13.3.0",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.13",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^6.15.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
